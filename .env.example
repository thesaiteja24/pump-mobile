# pump-mobile-v2 Environment Variables
# Copy this file to .env.development.local / .env.production.local and fill in values.
# NEVER commit .env.*.local files.

# ─── Required ──────────────────────────────────────────────────────────────────
# Used as the deep-link scheme and MMKV storage namespace. Must be set.
EXPO_PUBLIC_APP_SCHEME=pump

# Build environment: development | preview | production
APP_ENV=development

# ─── EAS ───────────────────────────────────────────────────────────────────────
# Your EAS project ID (from `eas build:configure` or the Expo dashboard).
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# ─── Sentry (optional) ─────────────────────────────────────────────────────────
# If omitted, Sentry is disabled. App still works normally.
EXPO_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
EXPO_PUBLIC_SENTRY_ORG=your-sentry-org
EXPO_PUBLIC_SENTRY_PROJECT=your-sentry-project

# ─── PostHog (optional) ────────────────────────────────────────────────────────
# If omitted, PostHog analytics is disabled.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your_key
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── OneSignal (optional) ──────────────────────────────────────────────────────
# If omitted, push notifications are disabled.
EXPO_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id

# ─── Web / Deep Links (optional) ───────────────────────────────────────────────
# Your production web host for universal links. Defaults to pump.thesaiteja.dev.
EXPO_PUBLIC_WEB_HOST=pump.thesaiteja.dev

# ─── Google OAuth2 (optional) ──────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-google-ios-client-id
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id
