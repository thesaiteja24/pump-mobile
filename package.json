{
  "name": "pump-mobile",
  "type": "module",
  "version": "1.0.0-alpha.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --clear",
    "android": "expo run:android --device",
    "ios": "expo run:ios",
    "clean": "expo prebuild --clean",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "doctor": "bunx expo-doctor",
    "prepare": "husky",
    "validate": "bun run lint:fix && bun run typecheck && bun run doctor && bunx expo install --check"
  },
  "dependencies": {
